export function getWeekStart(date: Date | string = new Date()): string {
  const d = typeof date === "string" ? new Date(date) : new Date(date);
  const dayOfWeek = d.getDay(); // 0 = dimanche, 1 = lundi
  const offset = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
  d.setDate(d.getDate() + offset);
  return d.toISOString().slice(0, 10);
}

export function formatWeekRange(weekStart: string): string {
  const start = new Date(weekStart);
  const end = new Date(start);
  end.setDate(end.getDate() + 6);
  return `Semaine du ${start.getDate()} au ${end.getDate()} ${end.toLocaleDateString("fr-FR", { month: "long", year: "numeric" })}`;
}
```

