Crée la migration `supabase/migrations/0010_meal_photo_search.sql` :

```sql
CREATE OR REPLACE FUNCTION public.match_food_items_by_keywords(
  keywords text[],
  limit_n int DEFAULT 5
)
RETURNS TABLE (
  id text,
  nom text,
  calories_100g numeric,
  proteines_100g numeric,
  glucides_100g numeric,
  lipides_100g numeric,
  sucres_100g numeric,
  fibres_100g numeric,
  sel_100g numeric,
  source text,
  rank real
) AS $$
  SELECT id, nom, calories_100g, proteines_100g, glucides_100g, lipides_100g,
         sucres_100g, fibres_100g, sel_100g, source,
         ts_rank(
           to_tsvector('french', nom),
           plainto_tsquery('french', array_to_string(keywords, ' '))
         ) AS rank
  FROM public.food_items
  WHERE to_tsvector('french', nom) @@ plainto_tsquery('french', array_to_string(keywords, ' '))
  ORDER BY rank DESC,
           CASE source
             WHEN 'CIQUAL_2020_ANSES' THEN 1
             WHEN 'FITNESS_CUSTOM_GENERIC' THEN 2
             ELSE 3
           END,
           length(nom)
  LIMIT limit_n;
$$ LANGUAGE sql STABLE;

GRANT EXECUTE ON FUNCTION public.match_food_items_by_keywords TO authenticated;
```

