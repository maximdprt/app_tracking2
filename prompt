## D.4 Queries Supabase

Crée `src/services/supabase/queries/schedule.ts` :

```typescript
import type { SupabaseClient } from "@supabase/supabase-js";
import type { Database } from "@/types/database";

type Client = SupabaseClient<Database>;
type ScheduledWorkout = Database["public"]["Tables"]["scheduled_workouts"]["Row"];
type ScheduledWorkoutInsert = Database["public"]["Tables"]["scheduled_workouts"]["Insert"];

export async function getScheduledWorkoutsForWeek(
  client: Client,
  userId: string,
  weekStart: string, // YYYY-MM-DD (lundi)
): Promise<ScheduledWorkout[]> {
  // Compute weekEnd = weekStart + 6 days
  const weekEnd = new Date(weekStart);
  weekEnd.setDate(weekEnd.getDate() + 6);
  const weekEndISO = weekEnd.toISOString().slice(0, 10);

  const { data, error } = await client
    .from("scheduled_workouts")
    .select("*")
    .eq("user_id", userId)
    .gte("scheduled_date", weekStart)
    .lte("scheduled_date", weekEndISO)
    .order("scheduled_date", { ascending: true });
  if (error) throw error;
  return data ?? [];
}

export async function getScheduledWorkoutForDate(
  client: Client,
  userId: string,
  date: string,
): Promise<ScheduledWorkout | null> {
  const { data, error } = await client
    .from("scheduled_workouts")
    .select("*")
    .eq("user_id", userId)
    .eq("scheduled_date", date)
    .eq("status", "planned")
    .maybeSingle();
  if (error) throw error;
  return data;
}

export async function upsertWeekSchedule(
  client: Client,
  userId: string,
  weekStart: string,
  workouts: Omit<ScheduledWorkoutInsert, "user_id">[],
): Promise<void> {
  // Delete existing scheduled (not completed) for the week
  const weekEnd = new Date(weekStart);
  weekEnd.setDate(weekEnd.getDate() + 6);
  const weekEndISO = weekEnd.toISOString().slice(0, 10);

  const { error: deleteError } = await client
    .from("scheduled_workouts")
    .delete()
    .eq("user_id", userId)
    .eq("status", "planned")
    .gte("scheduled_date", weekStart)
    .lte("scheduled_date", weekEndISO);
  if (deleteError) throw deleteError;

  if (workouts.length === 0) return;

  const { error: insertError } = await client
    .from("scheduled_workouts")
    .insert(workouts.map((w) => ({ ...w, user_id: userId })));
  if (insertError) throw insertError;
}

export async function markScheduledAsCompleted(
  client: Client,
  scheduledId: string,
  sessionId: string,
): Promise<void> {
  const { error } = await client
    .from("scheduled_workouts")
    .update({ status: "completed", session_id: sessionId })
    .eq("id", scheduledId);
  if (error) throw error;
}
```

